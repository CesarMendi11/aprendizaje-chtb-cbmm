# PostgreSQL operativo (solo ejemplo local; cambie la contraseña fuera de desarrollo)
ERP_ASSISTANT_POSTGRES_PASSWORD=erp_assistant_local
ERP_ASSISTANT_DATABASE_URL=postgresql+psycopg://erp_assistant:erp_assistant_local@127.0.0.1:5434/erp_assistant
ERP_ASSISTANT_DATABASE_ECHO=false
ERP_ASSISTANT_DATABASE_POOL_SIZE=5
ERP_ASSISTANT_DATABASE_MAX_OVERFLOW=5
ERP_ASSISTANT_CREATE_SYNC_JOBS=true
